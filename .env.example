# Production Environment Template
# Copy to .env and fill in actual values

# Database Configuration
DB_USER=aegisdb
DB_PASSWORD=change-this-to-secure-password
DB_NAME=aegis_api

# API Configuration
API_ENV=production
LOG_LEVEL=INFO
DEBUG=False

# Security
SECRET_KEY=generate-a-long-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=https://api.example.com,https://app.example.com

# Redis
REDIS_URL=redis://redis:6379

# GitHub Integration
GITHUB_TOKEN=
GITHUB_ORG=

# Grafana
GRAFANA_PASSWORD=admin

# API Server
HOST=0.0.0.0
PORT=8000
